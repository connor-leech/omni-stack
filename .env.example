# omni-stack environment template.
# Copy to .env (gitignored) and fill in. Variables flow to docker-compose.yml and the config
# templates in configs/. Re-run `./scripts/render-configs.sh` after editing to refresh
# configs/*.rendered.json.

# ---------------------------------------------------------------------------
# Host / network
# ---------------------------------------------------------------------------
# Hostname used to build URLs printed by bootstrap.sh. Works with MagicDNS so
# Tailnet devices can reach http://mini:<port>.
HOST_NAME=mini

# Ports (host-side). Internal container ports are fixed in compose.
AIOSTREAMS_PORT=3001
AIOMETADATA_PORT=3232

# Public base URLs. Leave empty to let compose default to http://${HOST_NAME}:<port>.
# Override if you front the stack with a reverse proxy / Tailscale Serve.
AIOSTREAMS_BASE_URL=
AIOMETADATA_BASE_URL=

# ---------------------------------------------------------------------------
# AIOStreams secrets
# ---------------------------------------------------------------------------
# Password that protects the /configure UI. Anything you like; minimum
# something not guessable. AIOStreams calls this ADDON_PASSWORD internally.
AIOSTREAMS_PASSWORD=change-me

# 64-character hex used for encrypting saved configs. Generate with:
#   openssl rand -hex 32
AIOSTREAMS_SECRET_KEY=

# ---------------------------------------------------------------------------
# Metadata provider keys (used by both AIOMetadata and AIOStreams)
# ---------------------------------------------------------------------------
TMDB_API_KEY=
TVDB_API_KEY=
MDBLIST_API_KEY=
RPDB_API_KEY=

# ---------------------------------------------------------------------------
# Debrid providers
# ---------------------------------------------------------------------------
# TorBox is the active debrid provider for this stack (Real-Debrid has been
# unreliable lately). Get a key at https://torbox.app
TORBOX_API_KEY=

# Real-Debrid is wired in the AIOStreams template but commented out. If/when
# you want to re-enable it: fill this in, then in the /configure UI enable the
# Real-Debrid service entry, save, and re-export.
# REAL_DEBRID_API_KEY=
